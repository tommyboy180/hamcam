# Copy this file to .env (or let the setup wizard at setup.php generate it for you)
# docker-compose.yml reads these automatically.

# Timezone for all containers
TZ=UTC

# Port the HamCAM web UI is published on (http://<host>:PORT)
HAMCAM_PORT=8765

# go2rtc ports (rarely need to change these)
GO2RTC_API_PORT=1984
GO2RTC_RTSP_PORT=8554

# Motion detection — keep these in sync with config.php
MOTION_ACTIVE_START=20:00
MOTION_ACTIVE_END=07:00
MOTION_ALWAYS_ON=false
MOTION_THRESHOLD=3000
MOTION_COOLDOWN=30
MOTION_LOG_LEVEL=INFO
MOTION_MAX_EVENTS=1000
