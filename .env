# Ships with sane defaults — docker-compose.yml reads this automatically.
# Edit by hand if you like, or let the setup wizard (setup.php) manage it.
# Port/timezone/motion-timing changes here need: docker compose up -d

# Timezone for all containers
TZ=UTC

# Port the HamCAM web UI is published on (http://<host>:PORT)
HAMCAM_PORT=8765

# go2rtc ports (rarely need to change these)
GO2RTC_API_PORT=1984
GO2RTC_RTSP_PORT=8554

# Motion detection — kept in sync with config.php by the setup wizard
MOTION_ACTIVE_START=20:00
MOTION_ACTIVE_END=07:00
MOTION_ALWAYS_ON=false
MOTION_THRESHOLD=3000
MOTION_COOLDOWN=30
MOTION_LOG_LEVEL=INFO
MOTION_MAX_EVENTS=1000
